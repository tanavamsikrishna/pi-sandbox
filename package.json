{
  "name": "pi-sandbox",
  "version": "0.1.8",
  "description": "OS-level sandboxing for pi with interactive permission prompts",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carderne/pi-sandbox.git"
  },
  "author": "Chris Arderne <chris@rdrn.me>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/carderne/pi-sandbox/issues"
  },
  "homepage": "https://github.com/carderne/pi-sandbox",
  "scripts": {
    "fmt": "oxfmt index.ts",
    "lint": "oxlint index.ts",
    "check": "tsc --noEmit",
    "ci:fmt": "oxfmt --check index.ts",
    "ci:lint": "npm run lint",
    "ci:check": "npm run check"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.37"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@types/node": "^24",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "typescript": "^5"
  },
  "overrides": {
    "minimatch": ">=10.2.1"
  }
}
